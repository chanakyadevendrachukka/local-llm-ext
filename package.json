{
  "name": "local-llm-chat",
  "displayName": "Local LLM Chat",
  "description": "Chat with local LLMs via YAML-configured models",
  "version": "0.1.0",
  "publisher": "local-llm-chat",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Chat",
    "Other"
  ],
  "activationEvents": [],
  "main": "./src/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "local-llm-chat.openChat",
        "title": "Local LLM Chat: Open Chat"
      },
      {
        "command": "local-llm-chat.refreshModels",
        "title": "Local LLM Chat: Refresh Models from Config"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "local-llm-chat",
          "title": "Local LLM Chat",
          "icon": "$(comment-discussion)"
        }
      ]
    },
    "views": {
      "local-llm-chat": [
        {
          "type": "webview",
          "id": "local-llm-chat.chatView",
          "name": "Chat"
        }
      ]
    }
  },
  "scripts": {
    "package": "node tools/package.js",
    "vscode:prepublish": "node tools/package.js"
  }
}
